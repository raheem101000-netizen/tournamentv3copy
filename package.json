  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "PORT=${PORT:-8080} NODE_ENV=development tsx --env-file=.env server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/index.js --banner:js=\"import { fileURLToPath } from 'url'; import { dirname } from 'path'; if (typeof import.meta.dirname === 'undefined') { Object.defineProperty(import.meta, 'dirname', { value: dirname(fileURLToPath(import.meta.url)) }); }\"",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "test:k6:smoke": "k6 run k6-tests/scenarios/smoke-test.js",
    "test:k6:load": "k6 run k6-tests/scenarios/load-test.js",
    "test:k6:stress": "k6 run k6-tests/scenarios/stress-test.js",
    "test:k6:spike": "k6 run k6-tests/scenarios/spike-test.js",
    "test:k6:all": "npm run test:k6:smoke && npm run test:k6:load && npm run test:k6:stress && npm run test:k6:spike"
  },
